# ─── Frontend environment variables ───────────────────────────────────────────
#
# Leave VITE_API_URL unset (or empty) when running via `npm run dev`.
# Vite will proxy /auth, /conversations and /ws to localhost:8000 automatically.
#
# Set it only when serving the built bundle from a different origin, e.g. Docker:
#   VITE_API_URL=http://localhost:8000
#
# VITE_API_URL=
